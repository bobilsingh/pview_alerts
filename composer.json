{
    "name": "company/alert-system",
    "description": "Jira-style Alert & Ticket Management System (CodeIgniter 4)",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "codeigniter4/framework": "~4.5.0",
        "phpmailer/phpmailer": "^6.9"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9",
        "mikey179/vfsstream": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Config\\": "app/Config/"
        },
        "exclude-from-classmap": [
            "**/Database/Migrations/**"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Support\\": "tests/_support/"
        }
    },
    "scripts": {
        "post-update-cmd": [
            "@composer dump-autoload"
        ]
    },
    "config": {
        "platform": {
            "php": "8.1.29"
        },
        "audit": {
            "ignore": {
                "PKSA-7ybs-j1bv-y5mc": "Acknowledged: production server is on PHP 8.1.29; once it upgrades to PHP 8.2+, remove the platform pin and the audit ignore, then bump codeigniter4/framework to ^4.7."
            }
        }
    }
}
