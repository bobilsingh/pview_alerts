#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------
CI_ENVIRONMENT = development
#CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
app.baseURL = 'http://localhost/pview_alerts/'

#--------------------------------------------------------------------
# FRAMEWORK DEFAULTS
#--------------------------------------------------------------------
# Database, mail, session, security, locale, timezone, and logger settings now use
# the related files under app/Config for simpler maintenance.

#--------------------------------------------------------------------
# EMAIL
#--------------------------------------------------------------------
email.fromEmail = 'alert@yourdomain.com'
email.fromName = 'Your App Team'
email.protocol = 'smtp'
email.SMTPHost = 'smtp.yourdomain.com'
email.SMTPUser = 'alert@yourdomain.com'
email.SMTPPass = 'your_smtp_password_here'
email.SMTPPort = 587
email.SMTPCrypto = 'tls'
email.mailType = 'html'
#----------------------------------------------------------------------
